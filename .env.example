# Meeting Copilot CLI
MEETING_TOPIC=
CONTEXT_REFRESH_INTERVAL_SECONDS=30
QUESTION_CONTEXT_SNAPSHOT_LIMIT=5

# Database settings
DATABASE_PATH=meeting_copilot.db
SUMMARIES_DIR=summaries

# Audio capture
AUDIO_CHUNK_SECONDS=5
AUDIO_FRAMES_PER_BUFFER=1024
AUDIO_SILENCE_RMS_THRESHOLD=120

# Transcription provider: faster_whisper or vosk
TRANSCRIPTION_PROVIDER=faster_whisper

# faster-whisper
WHISPER_MODEL_SIZE=small
WHISPER_LANGUAGE=pt
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Vosk
VOSK_MODEL_PATH=models/vosk-model-small-pt-0.3

# AI provider configuration
AI_PROVIDER=groq

STACKSPOT_AUTH_URL=https://idm.stackspot.com/YOUR_ACCOUNT_REALM/oidc/oauth/token
STACKSPOT_CLIENT_ID=
STACKSPOT_CLIENT_SECRET=
STACKSPOT_AGENT_URL=https://genai-inference-app.stackspot.com
STACKSPOT_AGENT_ID=
STACKSPOT_USE_CONVERSATION=true
STACKSPOT_STREAMING=false

DEVIN_API_URL=
DEVIN_API_KEY=

GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
